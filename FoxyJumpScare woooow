// ==UserScript==
// @name         FREDDYFAZBEAR AWUHAWUH
// @version      2026-04-07
// @description  Every second your browser is active, you roll a 1 in 10,000 chance for the foxy jumpscare to play with audio
// @author       You
// @match        *://*/*
// @icon         data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

  const Foxy = "https://i.redd.it/go7ir6novo8f1.gif";
  let JUMPSCARE;

  // Overlay
  const overlay = document.createElement('div')
  overlay.style = `
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    background: black;
    display: none;
    z-index: 999999;
    margin: 0;
    padding: 0;
    overflow: hidden;
`;

    // Foxy
    const img = document.createElement('img');
    img.src = Foxy;
    img.style.width = "100vw";
    img.style.height = "100vh";
    img.style.objectFit = "contain";

    overlay.appendChild(img);
    document.body.appendChild(overlay);

    // Rng Checker
    function Gamba () {
      JUMPSCARE = setInterval (() => {
        const roll = Math.floor(Math.random() * 10000) + 1;

        // Checks if we win
        if (roll === 10000) {
          FoxyJumpscare();
        }
       }, 1000);
      }

    function FoxyJumpscare() {
    clearInterval(JUMPSCARE);

    // This hopefully makes it so that the gif will play always from the beginning and never in between or in the middle.
    img.src = Foxy + "?t=" + new Date().getTime();

    overlay.style.display = "flex";

    setTimeout(() => {
        overlay.style.display = "none";
        Gamba();
    }, 1000); // Adjust this to match the length of your GIF
}
    Gamba();

})();
